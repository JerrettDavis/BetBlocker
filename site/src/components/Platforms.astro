<section class="landing-section">
  <h2 class="text-center">One platform. Every device.</h2>
  <p class="lead text-center" style="margin-inline:auto;">
    All platforms share a single Rust core engine, ensuring consistent blocking behavior everywhere.
  </p>
  <div class="platform-table-wrapper">
  <table class="platform-table">
    <thead>
      <tr>
        <th>Platform</th>
        <th>Protection Level</th>
